      "options": [
        {
          "label": "Symptomatic",
          "value": "Symptomatic"
        },
        {
          "label": "Cryptogenic / idiopathic",
          "value": "Cryptogenic"
        }
      ],
      "assess": "Symptomatic = seizure linked to a past condition (head injury, infection, stroke, other neurological cause). Cryptogenic/idiopathic = no identifiable structural cause."
    },
    {
