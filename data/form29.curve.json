{
  "schema_version": "1.0",
  "id": "form29",
  "kind": "curve",
  "meta": {
    "title": "Risk of epilepsy diagnosis after a first unprovoked seizure in dementia",
    "authors": "Mahamud Z, Mononen C, Brigo F, et al.",
    "journal": "Seizure",
    "year": 2020,
    "doi": "10.1016/j.seizure.2020.09.001",
    "outcome": "Risk of epilepsy diagnosis after a first unprovoked seizure in dementia",
    "clinical_utility": "To estimate the risk of an epilepsy diagnosis after a first unprovoked seizure in dementia, in relation to the 60 % cut-off specified in the ILAE definition of epilepsy. The study was register-based. Individuals with diagnostic codes of a first unprovoked seizure were identified in the Swedish Dementia Register (SveDem) or a three times larger age- and sex- matched pool of controls (n = 1039 in SveDem and 743 controls).",
    "pmid": "33068958"
  },
  "thresholds": {
    "group1": 20.0,
    "group2": 2.0
  },
  "predictors": [],
  "model": {
    "month_max_cum": 62,
    "month_max_cosy": 24,
    "horizon_months": 12,
    "cosy_axis_max": 40,
    "selector": "Dementia Type",
    "selector_info": "The dementia subtypes used in this analysis were defined based on diagnostic codes and clinical classifications as outlined in the study methods. These diagnoses were derived from the Swedish Dementia Registry (SveDem) and complemented by data from national healthcare registries. Diagnostic categories were assigned according to established clinical criteria, supported by neuroimaging, biomarkers, and clinician evaluations when available. Early-onset Alzheimer’s disease (EOAD) and late-onset Alzheimer’s disease (LOAD) were distinguished by an age cutoff of 65 years, with EOAD representing cases with symptom onset before this age, reflecting a more aggressive disease course. Mixed dementia included cases with evidence of both Alzheimer’s pathology and vascular contributions, often identified",
