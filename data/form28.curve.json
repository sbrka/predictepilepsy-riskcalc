 "kind": "curve",
 "meta": {
  "title": "COSY for ASM Withdrawal Risk Retrieval (including EEG Findings)",
  "doi": "10.1016/S1474-4422(17)30114-X",
  "authors": "Lamberink HJ, Otte WM, Geerts AT, et al.",
  "journal": "The Lancet Neurology",
  "year": 2017,
  "outcome": "Individualised prediction model of seizure recurrence and long-term outcomes after withdrawal of antiepileptic drugs in seizure-free patients: a systematic review and individual participant data meta-analysis",
  "clinical_utility": "People with epilepsy who became seizure-free while taking antiepileptic drugs might consider discontinuing their medication, with the possibility of increased quality of life because of the elimination of adverse events. The risk with this action, however, is seizure recurrence. The objectives of our study were to identify predictors of seizure recurrence and long-term seizure outcomes and to produce nomograms for estimation of individualised outcomes.",
  "pmid": "28483337"
 },
 "thresholds": {
  "group1": 20.0,
  "group2": 2.0
 },
 "predictors": [],
 "model": {
  "month_max_cum": 287,
  "month_max_cosy": 24,
  "horizon_months": 12,
  "cosy_axis_max": 40,
  "selector": "EEG",
  "selector_info": "In this study, electroencephalograms (EEGs) were evaluated to classify them as either normal or pathological prior to the withdrawal of antiepileptic drugs. EEGs were considered normal if they showed no epileptiform abnormalities, indicating an absence of abnormal electrical activity typically associated with seizures. In contrast, pathological EEGs were characterized by the presence of epileptiform abnormalities, such as spikes, sharp waves, or other irregular patterns that suggest an increased risk of seizure recurrence.",
