  "model": {
    "month_max_cum": 287,
    "month_max_cosy": 24,
    "horizon_months": 12,
    "cosy_axis_max": 40,
    "selector": "EEG",
    "selector_info": "In this study, electroencephalograms (EEGs) were evaluated to classify them as either normal or pathological prior to the withdrawal of antiepileptic drugs. EEGs were considered normal if they showed no epileptiform abnormalities, indicating an absence of abnormal electrical activity typically associated with seizures. In contrast, pathological EEGs were characterized by the presence of epileptiform abnormalities, such as spikes, sharp waves, or other irregular patterns that suggest an increased risk of seizure recurrence.",
