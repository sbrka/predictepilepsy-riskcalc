  "meta": {
    "title": "SeLECT: ASyS vs. RSyS",
    "doi": "",
    "authors": "SeLECT Consortium",
    "journal": "Unpublished — SeLECT Consortium data",
    "year": null,
    "outcome": "Risk of a (further) unprovoked seizure by index seizure type (acute symptomatic vs first/second remote symptomatic)",
    "clinical_utility": "An in-house model developed by the SeLECT consortium from its own (unpublished) data. It estimates the risk of a (further) unprovoked seizure according to the type of index seizure: acute symptomatic (ASyS — occurring within 7 days of the acute brain insult) versus first or second remote symptomatic (RSyS — unprovoked). This is NOT the published SeLECT score for late seizures after ischaemic stroke; it is a separate consortium analysis of acute-symptomatic vs remote-symptomatic seizure recurrence.",
    "pmid": "29413315",
    "unpublished": true
  },
  "thresholds": {
    "group1": 20.0,
    "group2": 2.0
  },
