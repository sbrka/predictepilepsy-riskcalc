  "kind": "curve",
  "meta": {
    "title": "Risk of Epilepsy Following a First Posttraumatic Seizure",
    "doi": "10.1212/CPJ.0000000000200409",
    "authors": "Karlander M, Håkansson S, Ljungqvist J, et al.",
    "journal": "Neurology Clinical Practice",
    "year": 2025,
    "outcome": "Risk of Epilepsy Following a First Posttraumatic Seizure",
    "clinical_utility": "Traumatic brain injury (TBI) is a common cause of epilepsy, and the risk increases with injury severity. Whether a first posttraumatic seizure (PTS) represents epilepsy is a common clinical problem, but often unknown. Prognostication is important for providing correct patient information and consideration of antiseizure medication.",
    "pmid": "39600560"
  },
  "thresholds": {
    "group1": 20.0,
    "group2": 2.0
  },
  "predictors": [],
  "model": {
    "month_max_cum": 120,
    "month_max_cosy": 60,
    "horizon_months": 12,
    "cosy_axis_max": 40,
    "selector": "TBI Severity and Classification",
    "selector_info": "This calculator is based on data from a comprehensive register-based cohort study conducted in Sweden between 2000 and 2010. The study analyzed the risk of epilepsy following a first posttraumatic seizure (PTS), focusing on the severity of traumatic brain injury (TBI) and the timing of seizure occurrence. The cohort included 4,239 individuals with a first seizure, of whom 2,286 had a prior TBI and 1,953 served as non-TBI controls. The severity of TBI was classified using ICD-10 diagnostic codes, and participants were distributed across six categories: non-TBI (1,953 individuals), mild TBI (1,426 individuals), fracture (111 individuals), extracerebral injury (308 individuals), diffuse cerebral injury (255 individuals), and focal cerebral injury (186 individuals). To use this calculator, you",
